<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12100E">

    <!-- TOP SECTION (Image + Name) -->
    <ImageView
        android:id="@+id/ingredientImage"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_ingredient_placeholder"
        android:contentDescription="Ingredient Image"
        app:tint="#7A9E7E"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/ingredientName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Chamomile"
        android:textColor="#C6A664"
        android:textSize="26sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/ingredientImage"
        app:layout_constraintStart_toEndOf="@id/ingredientImage"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"/>

    <!-- BODY SECTION -->

    <LinearLayout
        android:id="@+id/bodySection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/ingredientImage"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Type -->
        <TextView style="@style/DetailItem" android:text="Type: Herbal" />

        <!-- Origin -->
        <TextView style="@style/DetailItem" android:text="Origin: Mediterranean" />

        <!-- Flavor -->
        <TextView style="@style/DetailItem" android:text="Flavor: Floral, Sweet" />

        <!-- Effects -->
        <TextView style="@style/DetailItem" android:text="Effects: Calming, Sleep Aid" />

        <!-- Caffeine -->
        <TextView style="@style/DetailItem" android:text="Caffeine: ★☆☆☆☆" />

        <!-- Common Uses -->
        <TextView style="@style/DetailItem" android:text="Common Uses: Tea, Relaxation" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A soothing herb used for calming the mind and preparing restful brews within the Healer's Hearth tradition."
            android:textColor="#F2EAD3"
            android:fontFamily="serif"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#1B1815"
        app:itemIconTint="#8A7F6A"
        app:itemTextColor="#8A7F6A"
        app:itemRippleColor="#2F2A24"
        app:itemActiveIndicatorStyle="@null"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>