<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12100E">

    <!-- LOGIN CARD -->
    <LinearLayout
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#1B1815"
        android:layout_margin="24dp"
        android:gravity="center_horizontal"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_grimoire"
            android:tint="#C6A664"
            android:layout_marginBottom="12dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THE HEALER'S HEARTH"
            android:textColor="#C6A664"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGIN"
            android:textColor="#F2EAD3"
            android:textSize="22sp"
            android:fontFamily="serif"
            android:layout_marginBottom="20dp"/>

        <!-- Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Email or Phone"
            android:padding="12dp"
            android:textColor="#F2EAD3"
            android:hintTextColor="#8A7F6A"
            android:background="#231F1B"
            android:layout_marginBottom="12dp"/>

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textColor="#F2EAD3"
            android:hintTextColor="#8A7F6A"
            android:background="#231F1B"
            android:layout_marginBottom="8dp"/>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="#7A9E7E"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"/>

        <!-- LOGIN BUTTON -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="ENTER THE HEARTH"
            android:textColor="#12100E"
            android:backgroundTint="#C6A664"
            android:fontFamily="serif"
            android:layout_marginBottom="16dp"/>

        <!-- Signup -->
        <TextView
            android:id="@+id/tvNotSignedUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not signed up yet? Create account"
            android:textColor="#8A7F6A"
            android:textSize="12sp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>