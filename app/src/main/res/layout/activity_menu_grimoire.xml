<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12100E">

    <!-- Title -->
    <TextView
        android:id="@+id/titleGrimoire"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu Grimoire"
        android:textColor="#C6A664"
        android:textSize="26sp"
        android:letterSpacing="0.08"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"/>

    <!-- Grimoire Icon -->
    <ImageView
        android:id="@+id/grimoireIcon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_grimoire"
        android:contentDescription="Grimoire"
        app:layout_constraintTop_toBottomOf="@id/titleGrimoire"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp"
        app:tint="#E6D3A3" />

    <!-- Ingredients List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ingredientsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/grimoireIcon"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#1B1815"
        app:itemIconTint="#8A7F6A"
        app:itemTextColor="#8A7F6A"
        app:itemRippleColor="#2F2A24"
        app:itemActiveIndicatorStyle="@null"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>